{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "github@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "telegram@claude-plugins-official": true
  },
  "disabledMcpjsonServers": [
    "Claude Preview"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:53117/stop",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:53117/user",
            "timeout": 5
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:53117/drain",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:53117/drain",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:53117/stream",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
